# ==========================================================================
# super-train — modelo de variáveis de ambiente (versionado).
# Copie para .env (git-ignored) e preencha os valores reais.
# ==========================================================================

# --- Supabase: ADMIN / MCP (NUNCA expor no frontend — sem prefixo VITE_) ---
# Personal access token: Supabase → Account → Access Tokens → Generate new token
SUPABASE_ACCESS_TOKEN=

# --- Frontend (Vite expõe tudo que começa com VITE_ no bundle público) ---
# Públicos por design (protegidos por RLS / restrição de URL):
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_MAPBOX_TOKEN=
